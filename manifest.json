{
    "manifest_version": 3,
    "name": "My Color Picker",
    "description": "A simple color picker extension for Chrome.",
    "version": "1.1.3",
    "permissions": [
        "notifications" 
    ],
    "icons": {
        "128": "default_icon128_white.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": "default_icon128_white.png"
    }
}